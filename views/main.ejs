<!DOCTYPE html>
<html>
<meta http-equiv="X-UA-Compatible" content="ie=edge">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="style.css">
</head>
<header class="NurseryTitle">Nursery Organization</header>
<body lang="en">
    <div class="container">
        <button class="table_patient" id="patientBT">Patient</button>
        
        <button class="table_family" id="familyBT">Family</button>
        <button class="table_faculty" id="facultyBT">Faculty</button>
        <button class="table_payment" id="paymentBT">Payment Processing</button>
    </div>
    <div class="resultContainer">
        <!-- <p class="result" id="tableView">Results Here</p> -->
        <h1><%= title %></h1>

        <% if(action == 'add') { %>
            
        <% } else { %>
        <div class="card">
            <div class="card-reader">
                <div class="row">
                    <div class="col">Sample Data</div>
                    <div class="col"></div>
                </div>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-bordered">
                        <tr>
                            <th>facultyID</th>
                            <th>facultyLastName</th>
                            <th>facultyType</th>
                        </tr>
                        <% if(sampleData.length > 0){ 
                            sampleData.forEach(function(data){ 
                        %>
                        <tr>
                            <td><%= data.facultyID %></td>
                            <td><%= data.facultyLastName %></td>
                            <td><%= data.facultyType %></td>
                            <td></td>
                        </tr>
                        <%
                            });
                        }
                        else 
                        {  
                        %>
                        <tr>
                            <td colspan="5">No data found</td>
                        </tr>
                        <% 
                        } 
                        %>
                    </table>
                </div>
            </div>
        </div>
        <% } %> 
    </div>
    <!-- <script src="index.js"></script> -->
    <!-- <script type="module" src="database.js"></script> -->
     <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM" crossorigin="anonymous"></script>
</body>
</html>